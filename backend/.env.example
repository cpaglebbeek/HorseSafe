# HorseSafe backend env-template. Productie: /opt/horsesafe/.env (mode 600).
# Dev: kopieer naar backend/.env en pas waarden aan.

# Pad-instellingen
HORSESAFE_DB_PATH=./db/horsesafe.db
HORSESAFE_VAULTS_DIR=./vaults

# JWT (productie: 32 bytes hex via `openssl rand -hex 32`)
HORSESAFE_JWT_SECRET=replace-me-in-production
HORSESAFE_JWT_TTL_MINUTES=720

# Cookies
HORSESAFE_COOKIE_NAME=horsesafe_session
HORSESAFE_COOKIE_SECURE=true
HORSESAFE_COOKIE_SAMESITE=strict

# Argon2id (account-pw hashing — server-side)
HORSESAFE_ARGON2_TIME_COST=3
HORSESAFE_ARGON2_MEMORY_KIB=65536
HORSESAFE_ARGON2_PARALLELISM=4

# Throttle
HORSESAFE_FAILED_LOGIN_MAX=5
HORSESAFE_FAILED_LOGIN_WINDOW_MINUTES=15

# Vault
HORSESAFE_VAULT_MAX_BYTES=52428800

HORSESAFE_LOG_LEVEL=INFO
